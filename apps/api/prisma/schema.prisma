generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ 用户与认证 ============

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  name         String?
  hashedPassword String
  role         String   @default("developer") // admin | developer | viewer
  refreshToken String?  @map("refresh_token")
  avatarUrl    String?  @map("avatar_url")
  plan         String   @default("free") // free | pro | enterprise
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  projects Project[]
  memberships Membership[]

  @@map("users")
}

// ============ 组织 / 多租户 ============

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  plan      String   @default("free") // free | pro | enterprise（计费主体）
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  memberships   Membership[]
  projects      Project[]
  importBatches ImportBatch[]

  @@map("organizations")
}

model Membership {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  role      String   @default("member") // owner | admin | member（组织内角色）
  createdAt DateTime @default(now()) @map("created_at")

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
  @@index([orgId])
  @@map("memberships")
}

// ============ 项目 ============

model Project {
  id                     String   @id @default(uuid()) @db.Uuid
  userId                 String   @map("user_id") @db.Uuid
  orgId                  String?  @map("org_id") @db.Uuid // 租户数据根：2-1a 可空，2-1b 回填，后续改必填
  name                   String
  description            String?
  appType                String?  @map("app_type")
  status                 String   @default("needs_input") // 内部状态
  publicStatusLabel      String?  @map("public_status_label") // 用户可见状态
  structuredRequirement  Json?    @map("structured_requirement")
  planSummary            Json?    @map("plan_summary")
  moduleMap              Json?    @map("module_map")
  acceptanceChecklist    Json?    @map("acceptance_checklist")
  demoUrl                String?  @map("demo_url")
  demoHtml               String?  @map("demo_html")
  demoProgress           Json?    @map("demo_progress") // 预览生成进度 {phase,percent,message,startedAt,attempt}
  themeConfig            Json?    @map("theme_config") // demo 外观主题 {primary,mode,radius}（Phase A 换肤）
  referenceShots         Json?    @map("reference_shots") // 参考截图引用 [{name, storageKey}]，供 demo 看图复刻
  shotLayouts            Json?    @map("shot_layouts")    // 看图复刻的布局描述 [{name, layout}]，供人在回路核对纠错
  productionUrl          String?  @map("production_url")
  latestBuildId          String?  @map("latest_build_id") @db.Uuid
  sourceExportEnabled    Boolean  @default(false) @map("source_export_enabled")
  packageExportEnabled   Boolean  @default(false) @map("package_export_enabled")
  repositoryExportEnabled Boolean @default(false) @map("repository_export_enabled")
  specConfirmedAt        DateTime? @map("spec_confirmed_at")
  specVersion            Int       @default(0) @map("spec_version")
  guardianEnabled        Boolean   @default(false) @map("guardian_enabled") // 是否进入 Guardian 守护生命周期（上线即入列）
  autoIterateState       Json?     @map("auto_iterate_state") // 自迭代运行的持久状态（真相源）：status/round/score/rounds/phases/terminal，供前端对账自愈
  dataModel              String?   @map("data_model")      // 路 B(ADR-0001)：LLM 产出的数据模型(Prisma schema 文本)，平台据此建表
  backendRuntime         Json?     @map("backend_runtime") // 后端运行时描述符 BackendRuntimeDescriptor：kind/schemaName/resources/status
  appSchema              Json?     @map("app_schema")      // Schema 驱动(S4)：页面装配清单 AppSchema，编辑面板改它即重渲染 demoHtml
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  user                     User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  org                      Organization?       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  messages                 ProjectMessage[]
  modules                  Module[]
  tasks                    Task[]
  feedbackItems            FeedbackItem[]
  builds                   Build[]
  deliveryOptions          DeliveryOption?
  decisionLogs             DecisionLog[]
  errorEvents              ErrorEvent[]
  caseReviews              CaseReview[]
  experienceRecommendations ExperienceRecommendation[]
  demoSnapshots             DemoSnapshot[]
  deployments               Deployment[]
  systemLocks               SystemLock[]
  specification             Specification?
  testDeployments           TestDeployment[]
  importBatches             ImportBatch[]
  guardianChecks            GuardianCheck[]
  guardianRemediations      GuardianRemediation[]
  buildModules              BuildModule[]
  buildJournal              BuildJournalEntry[]

  @@index([userId])
  @@index([orgId])
  @@map("projects")
}

// ============ 守护中心（Guardian）============

/**
 * 产品实例守护巡检记录（Phase 2 最小闭环）。
 * 定时复用验收引擎对已上线项目跑关键场景，落一条健康快照：可追溯、可回放。
 */
model GuardianCheck {
  id           String   @id @default(uuid()) @db.Uuid
  projectId    String   @map("project_id") @db.Uuid
  orgId        String?  @map("org_id") @db.Uuid
  healthScore  Int      @map("health_score") // 0-100 综合健康分
  status       String   // healthy | degraded | critical | unknown
  passRate     Float?   @map("pass_rate")     // 验收通过率 0-1
  overallScore Int?     @map("overall_score")  // 传感器总分 0-100（实现质量旁证）
  total        Int      @default(0)
  passed       Int      @default(0)
  failed       Int      @default(0)
  manual       Int      @default(0)
  trigger      String   @default("scheduled") // scheduled | manual
  detail       Json?    // 摘要：未通过/待人工场景名等
  checkedAt    DateTime @default(now()) @map("checked_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, checkedAt])
  @@map("guardian_checks")
}

/**
 * 守护分级修复记录（Phase 2）。
 * 巡检发现问题后，按风险分四级：alert 提醒 / suggest 建议修复 / confirm 确认修复 / auto 低风险自动修复。
 * 每条修复都带：影响范围(impactScope)、验证结果(verifyResult 修复前后健康分)、回滚点(rollbackPointId)。
 */
model GuardianRemediation {
  id              String    @id @default(uuid()) @db.Uuid
  projectId       String    @map("project_id") @db.Uuid
  orgId           String?   @map("org_id") @db.Uuid
  checkId         String?   @map("check_id") @db.Uuid // 触发它的巡检记录
  level           String    // alert | suggest | confirm | auto
  issue           String    // 问题描述（如未通过场景）
  proposedAction  String?   @map("proposed_action") // 拟修复动作
  status          String    @default("pending") // pending | applied | skipped | rolled_back | failed
  impactScope     Json?     @map("impact_scope")  // 影响范围（模块/资源/文件）
  verifyResult    Json?     @map("verify_result") // 验证结果（修复前后健康分等）
  rollbackPointId String?   @map("rollback_point_id") @db.Uuid // 回滚点（DemoSnapshot id）
  createdAt       DateTime  @default(now()) @map("created_at")
  resolvedAt      DateTime? @map("resolved_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@map("guardian_remediations")
}

// ============ 自治建造回路（ADR-0005）============

/**
 * 建造计划的一个模块（模块 DAG 的节点）。状态机：pending→building→testing→done|blocked。
 * 编排器无状态地读这张表 + BuildJournal 决定下一步，使建造跨上下文/会话续跑。
 */
model BuildModule {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  name      String   // 模块名（DAG 内唯一，供 deps 引用）
  spec      String?  // 模块规格（自然语言/结构化）
  deps      Json?    // 依赖的模块 name 数组（拓扑序约束）
  status    String   @default("pending") // pending | building | testing | done | blocked
  orderIdx  Int      @default(0) @map("order_idx")
  result    Json?    // 产物引用 / 测试结果摘要
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, orderIdx])
  @@map("build_modules")
}

/**
 * append-only 交接日志（= ADR/记忆/小结 的产品内化）。库是真相源，编排器据此续跑。
 */
model BuildJournalEntry {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  moduleId  String?  @map("module_id") @db.Uuid
  phase     String   // plan | generate | test | done | blocked | resume
  summary   String
  detail    Json?    // decisions / knownIssues / testResult / shotRef
  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@map("build_journal_entries")
}

// ============ 项目消息 ============

model ProjectMessage {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  role      String   // user | assistant | system_internal
  content   String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_messages")
}

// ============ 模块 ============

model Module {
  id           String   @id @default(uuid()) @db.Uuid
  projectId    String   @map("project_id") @db.Uuid
  moduleKey    String   @map("module_key")
  name         String
  description  String?
  pageKeys     Json?    @map("page_keys")
  apiKeys      Json?    @map("api_keys")
  dataKeys     Json?    @map("data_keys")
  dependencies Json?
  status       String   @default("planned")
  version      Int      @default(1)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks         Task[]
  feedbackItems FeedbackItem[]

  @@unique([projectId, moduleKey])
  @@map("modules")
}

// ============ 任务 ============

model Task {
  id            String   @id @default(uuid()) @db.Uuid
  projectId     String   @map("project_id") @db.Uuid
  moduleId      String?  @map("module_id") @db.Uuid
  type          String   // frontend | backend | database | test | fix | deploy | export_source | export_package | export_repository | export_database_schema | export_deployment_config | case_review | experience_recommendation
  title         String
  description   String
  priority      Int      @default(100)
  dependencies  Json?
  status        String   @default("pending") // pending | running | completed | failed | blocked
  inputPayload  Json?    @map("input_payload")
  resultPayload Json?    @map("result_payload")
  retryCount    Int      @default(0) @map("retry_count")
  maxRetries    Int      @default(3) @map("max_retries")
  errorMessage  String?  @map("error_message")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  project      Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  module       Module?        @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  decisionLogs DecisionLog[]
  errorEvents  ErrorEvent[]
  generatedTaskFeedback FeedbackItem[] @relation("GeneratedTask")
  demoSnapshots         DemoSnapshot[]

  @@index([projectId])
  @@map("tasks")
}

// ============ 批注反馈 ============

model FeedbackItem {
  id             String   @id @default(uuid()) @db.Uuid
  projectId      String   @map("project_id") @db.Uuid
  moduleId       String?  @map("module_id") @db.Uuid
  moduleKey      String?  @map("module_key")
  elementPath    String?  @map("element_path")
  pageUrl        String?  @map("page_url")
  screenshotUrl  String?  @map("screenshot_url")
  comment        String
  feedbackType   String   @default("bug") @map("feedback_type") // bug | change_request
  status         String   @default("new") // new | processing | resolved
  generatedTaskId String? @map("generated_task_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  module       Module? @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  generatedTask Task?  @relation("GeneratedTask", fields: [generatedTaskId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@map("feedback_items")
}

// ============ Demo 快照（版本历史） ============

model DemoSnapshot {
  id        String   @id @default(cuid())
  projectId String   @map("project_id") @db.Uuid
  html      String   // 修改前的完整 demoHtml 快照
  taskId    String?  @map("task_id") @db.Uuid
  source    String   // 'demo_generate' | 'pipeline_execute' | 'manual_rollback'
  version   Int      // 项目内自增版本号，从 1 开始
  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task    Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([projectId, version])
  @@map("demo_snapshots")
}

// ============ 构建记录 ============

model Build {
  id                  String   @id @default(uuid()) @db.Uuid
  projectId           String   @map("project_id") @db.Uuid
  version             Int
  commitHash          String?  @map("commit_hash")
  artifactUrl         String?  @map("artifact_url")
  demoUrl             String?  @map("demo_url")
  productionUrl       String?  @map("production_url")
  sourceZipUrl        String?  @map("source_zip_url")
  packageZipUrl       String?  @map("package_zip_url")
  repositoryUrl       String?  @map("repository_url")
  databaseSchemaUrl   String?  @map("database_schema_url")
  deploymentConfigUrl String?  @map("deployment_config_url")
  readmeUrl           String?  @map("readme_url")
  envExampleUrl       String?  @map("env_example_url")
  testReport          Json?    @map("test_report")
  status              String   @default("created") // created | building | success | failed
  createdAt           DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deployments Deployment[]

  @@index([projectId])
  @@map("builds")
}

// ============ 部署记录 ============

model Deployment {
  id           String   @id @default(uuid()) @db.Uuid
  projectId    String   @map("project_id") @db.Uuid
  buildId      String?  @map("build_id") @db.Uuid
  html         String                         // 部署时刻的 HTML 快照
  status       String   @default("deploying") // deploying | deployed | failed
  provider     String   @default("internal")  // internal | railway | flyio
  externalUrl  String?  @map("external_url")
  errorMessage String?  @map("error_message")
  createdAt    DateTime @default(now()) @map("created_at")
  deployedAt   DateTime? @map("deployed_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  build   Build?  @relation(fields: [buildId], references: [id], onDelete: SetNull)

  @@index([projectId, status])
  @@map("deployments")
}

model DeliveryOption {
  id                      String   @id @default(uuid()) @db.Uuid
  projectId               String   @unique @map("project_id") @db.Uuid
  onlineUrlEnabled        Boolean  @default(true) @map("online_url_enabled")
  sourceZipEnabled        Boolean  @default(false) @map("source_zip_enabled")
  packageExportEnabled    Boolean  @default(false) @map("package_export_enabled")
  gitRepositoryEnabled    Boolean  @default(false) @map("git_repository_enabled")
  databaseExportEnabled   Boolean  @default(false) @map("database_export_enabled")
  deploymentConfigEnabled Boolean  @default(false) @map("deployment_config_enabled")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("delivery_options")
}

// ============ 决策规则（内部） ============

model DecisionRule {
  id          String   @id @default(uuid()) @db.Uuid
  ruleKey     String   @unique @map("rule_key")
  name        String
  stage       String
  description String?
  conditions  Json
  actions     Json
  priority    Int      @default(100)
  isActive    Boolean  @default(true) @map("is_active")
  version     Int      @default(1)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("decision_rules")
}

// ============ 决策日志（内部） ============

model DecisionLog {
  id             String   @id @default(uuid()) @db.Uuid
  projectId      String?  @map("project_id") @db.Uuid
  taskId         String?  @map("task_id") @db.Uuid
  ruleKey        String?  @map("rule_key")
  stage          String
  inputContext   Json     @map("input_context")
  decisionResult Json     @map("decision_result")
  actionTaken    String?  @map("action_taken")
  outcome        String?
  createdAt      DateTime @default(now()) @map("created_at")

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  task    Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@map("decision_logs")
}

// ============ 错误模式（内部） ============

model ErrorPattern {
  id                String   @id @default(uuid()) @db.Uuid
  patternKey        String   @unique @map("pattern_key")
  name              String
  publicName        String?  @map("public_name")
  stage             String?
  signals           Json?
  commonCauses      Json?    @map("common_causes")
  recommendedActions Json?   @map("recommended_actions")
  autoFixable       Boolean  @default(false) @map("auto_fixable")
  severity          String   @default("medium")
  successRate       Decimal? @default(0) @map("success_rate")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  errorEvents ErrorEvent[]

  @@map("error_patterns")
}

// ============ 错误事件（内部） ============

model ErrorEvent {
  id               String   @id @default(uuid()) @db.Uuid
  projectId        String?  @map("project_id") @db.Uuid
  taskId           String?  @map("task_id") @db.Uuid
  patternId        String?  @map("pattern_id") @db.Uuid
  rawError         String?  @map("raw_error")
  sanitizedError   String?  @map("sanitized_error")
  stage            String?
  matchedConfidence Decimal? @map("matched_confidence")
  actionTaken      String?  @map("action_taken")
  resolved         Boolean  @default(false)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  project Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  task    Task?         @relation(fields: [taskId], references: [id], onDelete: SetNull)
  pattern ErrorPattern? @relation(fields: [patternId], references: [id], onDelete: SetNull)

  @@map("error_events")
}

// ============ 项目复盘（内部） ============

model CaseReview {
  id                  String   @id @default(uuid()) @db.Uuid
  projectId           String   @map("project_id") @db.Uuid
  appType             String?  @map("app_type")
  summary             String?
  originalRequirement Json?    @map("original_requirement")
  finalPlan           Json?    @map("final_plan")
  feedbackCount       Int      @default(0) @map("feedback_count")
  mainErrors          Json?    @map("main_errors")
  fixStrategies       Json?    @map("fix_strategies")
  deliveryType        String?  @map("delivery_type")
  userAcceptanceResult String? @map("user_acceptance_result")
  reusableLessons     Json?    @map("reusable_lessons")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("case_reviews")
}

// ============ 经验推荐（内部） ============

model ExperienceRecommendation {
  id                  String   @id @default(uuid()) @db.Uuid
  projectId           String?  @map("project_id") @db.Uuid
  stage               String
  recommendationType  String   @map("recommendation_type") // question | module_template | test_case | fix_strategy | delivery_check | risk_warning
  sourceType          String?  @map("source_type")
  sourceId            String?  @map("source_id") @db.Uuid
  recommendation      Json
  accepted            Boolean?
  outcome             String?
  createdAt           DateTime @default(now()) @map("created_at")

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@map("experience_recommendations")
}

// ============ 系统锁（全局唯一） ============

model SystemLock {
  id        String   @id                      // 固定值 "auto_iteration" — 主键约束保证单例
  projectId String   @map("project_id") @db.Uuid
  taskId    String   @map("task_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("system_locks")
}

// ============ 规格确认 ============

model Specification {
  id              String   @id @default(uuid()) @db.Uuid
  projectId       String   @unique @map("project_id") @db.Uuid
  version         Int      @default(1)
  status          String   @default("draft") // draft | frozen | revised
  frozenAt        DateTime? @map("frozen_at")

  // 确认内容（结构化 JSON）
  targetUsers     Json?    @map("target_users")       // [{role, description}]
  coreFunctions   Json?    @map("core_functions")     // [{name, description, priority: must|nice|later}]
  outOfScope      Json?    @map("out_of_scope")       // [{name, reason}]
  pages           Json?    @map("pages")              // [{name, route, description}]
  roles           Json?    @map("roles")              // [{name, permissions[]}]
  dataModels      Json?    @map("data_models")        // [{name, fields[{name,type,required}]}]
  businessRules   Json?    @map("business_rules")     // [{name, description, trigger, outcome}]
  acceptanceScenarios Json? @map("acceptance_scenarios") // [{name, given, when, then, priority, provenance[], coverage[]}]

  // 验收报告（P15-Y 可验收/可追溯）
  verificationResults Json?     @map("verification_results") // [{scenarioName, status: pass|fail|manual, coverage[], provenance[], checks[], evidence, verifiedAt}]
  passRate            Float?    @map("pass_rate")            // 通过率 0-1，门控交付
  verifiedAt         DateTime? @map("verified_at")          // 最近一次验收时间

  // 预测信息（冻结时的快照）
  estimatedCostRmb Int?    @map("estimated_cost_rmb")
  estimatedDays    Int?    @map("estimated_days")
  primaryRisks     Json?   @map("primary_risks")

  // 变更历史
  changeLog       Json?    @map("change_log") // [{version, changedAt, field, oldValue, newValue, reason}]

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("specifications")
}

// ============ 测试环境部署 ============

model TestDeployment {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  status      String   @default("preparing") // preparing | building | deploying | ready | failed | destroyed
  version     Int      @default(1)

  // 部署信息
  containerId String?  @map("container_id")
  testUrl     String?  @map("test_url")
  adminUser   String?  @map("admin_user")
  adminPass   String?  @map("admin_pass")
  port        Int?     // 动态分配的端口

  // 进度信息
  currentStep String?  @map("current_step")  // 当前执行步骤
  stepsLog    Json?    @map("steps_log")     // [{step, status, message, ts}]
  progress    Int      @default(0)           // 0-100

  // 健康检查
  healthStatus String? @map("health_status") // healthy | unhealthy | unknown
  lastHealthAt DateTime? @map("last_health_at")

  errorMessage String?  @map("error_message")
  startedAt    DateTime? @map("started_at")
  readyAt      DateTime? @map("ready_at")
  destroyedAt  DateTime? @map("destroyed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@map("test_deployments")
}

// ============ 专业资料导入（Phase 1.5，精简版）============

enum ImportBatchStatus {
  uploading
  parsing
  ready_for_review
  confirmed
  failed
}

enum AssetCategory {
  document
  prototype
  design
  other
}

enum UnderstandingStatus {
  draft
  confirmed
}

/// 导入批次：一批专业资料的生命周期载体，挂租户(org)与可选项目，不污染 Project.status
model ImportBatch {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String?  @map("org_id") @db.Uuid
  projectId String?  @map("project_id") @db.Uuid
  name      String?
  status    ImportBatchStatus @default(uploading)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org           Organization?             @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project       Project?                  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assets        AssetFile[]
  understanding RequirementUnderstanding?

  @@index([orgId])
  @@index([projectId])
  @@map("import_batches")
}

/// 上传文件：只存对象存储引用 + checksum(秒传/解析缓存) + LLM 逐份理解笔记
model AssetFile {
  id           String    @id @default(uuid()) @db.Uuid
  batchId      String    @map("batch_id") @db.Uuid
  category     AssetCategory
  fileName     String    @map("file_name")
  mimeType     String?   @map("mime_type")
  sizeBytes    BigInt?   @map("size_bytes")
  storageKey   String    @map("storage_key")
  domainResident Boolean @default(true) @map("domain_resident") // 字节是否落域内对象存储(§1.1 数据不出域审计)
  checksum     String?
  parseSummary Json?     @map("parse_summary")
  parsedAt     DateTime? @map("parsed_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  batch ImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([checksum])
  @@map("asset_files")
}

/// 处理文档：汇总各份理解的半结构化结果。features/pages 等 JSON 内每条带内联 source(溯源)
model RequirementUnderstanding {
  id              String   @id @default(uuid()) @db.Uuid
  batchId         String   @unique @map("batch_id") @db.Uuid
  positioning     String?
  roles           Json?
  features        Json?
  pages           Json?
  flows           Json?
  conflicts       Json?
  suggestions     Json?    // 资深 PM 视角：建议补充/待明确的需求点(开放项，供人工补全)
  confidenceScore Float?   @map("confidence_score")
  status          UnderstandingStatus @default(draft)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  batch     ImportBatch           @relation(fields: [batchId], references: [id], onDelete: Cascade)
  questions RequirementQuestion[]

  @@map("requirement_understandings")
}

/// 低置信度/冲突时的待确认问题(人在回路)
model RequirementQuestion {
  id              String   @id @default(uuid()) @db.Uuid
  understandingId String   @map("understanding_id") @db.Uuid
  question        String
  severity        String?  // high|medium：关联冲突严重度，用于物化门控(P15-7)
  answer          String?
  resolved        Boolean  @default(false)
  createdAt       DateTime @default(now()) @map("created_at")

  understanding RequirementUnderstanding @relation(fields: [understandingId], references: [id], onDelete: Cascade)

  @@index([understandingId])
  @@map("requirement_questions")
}
